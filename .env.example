# URL del sitio (para enlaces en emails de recuperación)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=your-supabase-url

# Supabase JWT Secret (for advanced use cases)
SUPABASE_JWT_SECRET=your-jwt-secret

# Scan QR - Sistema de asistencia (generar con: openssl rand -base64 48)
SCAN_JWT_SECRET=your-scan-jwt-secret

# Email (SMTP - Nodemailer)
# Requerido para enviar emails de aprobación, reseteo de contraseña, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
# El remitente se configura automáticamente como "Do Not Reply - Movilidad" <SMTP_USER>

# Postgres Configuration (optional - for direct database access)
SUPABASE_POSTGRES_URL=your-postgres-url
SUPABASE_POSTGRES_URL_NON_POOLING=your-postgres-url-non-pooling
SUPABASE_POSTGRES_PRISMA_URL=your-postgres-prisma-url
SUPABASE_POSTGRES_HOST=your-postgres-host
SUPABASE_POSTGRES_DATABASE=postgres
SUPABASE_POSTGRES_USER=postgres
SUPABASE_POSTGRES_PASSWORD=your-postgres-password
